# ============================================================
# Parceria Premiada — Deploy Environment
# Copie para .env e preencha com os valores reais
# NUNCA commitar o .env preenchido
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Baked no bundle do Next.js em build time
SUPABASE_URL=https://supabase.mundodosbots.app.br
SUPABASE_ANON_KEY=

# ── n8n ──────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.mundodosbots.app.br/webhook/parceria-premiada/participant-created
N8N_DELAY_SEGUNDOS=3
N8N_LIMITE_POR_EXECUCAO=50

# ── Evolution API ─────────────────────────────────────────────
EVOLUTION_API_URL=https://api.mundodosbots.app.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=Parceria Premiada

# ── URLs públicas ─────────────────────────────────────────────
PUBLIC_SITE_URL=https://parceriapremiada.app.br
ADMIN_API_BASE_URL=https://admin.parceriapremiada.app.br
